# constitution-rag environment variables
# Copy to .env and fill in real values

# ── OpenAI ──
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=  # optional, for custom endpoints

# ── PostgreSQL ──
DB_HOST=db
DB_PORT=5432
DB_NAME=constitution_rag
DB_USER=constitution_rag
DB_PASSWORD=CHANGE_ME

# NOTE: When running inside docker-compose, DB_HOST=db and DB_PORT=5432
# (internal Docker network). When running locally, use DB_HOST=127.0.0.1
# and DB_PORT=55432 (mapped host port).
